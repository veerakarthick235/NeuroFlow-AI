# NeuroFlow AI – Environment Variables
# Copy this file to .env and fill in your values

# --- Database ---
# SQLite (default, zero-config):
DATABASE_URL=sqlite:///./neuroflow.db

# PostgreSQL (uncomment and configure if you have PostgreSQL):
# DATABASE_URL=postgresql://user:password@localhost:5432/neuroflow

# --- JWT Auth ---
SECRET_KEY=your-super-secret-key-change-this-in-production-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- OpenAI ---
# Leave blank to use built-in intelligent dummy data (great for demos)
OPENAI_API_KEY=580f6a43c842c2c89e73ba00e50f8323
OPENAI_BASE_URL=https://api.bytez.com/v1
OPENAI_MODEL=openai/gpt-4o-mini
